# Cache directives — applied by Cloudflare Pages / Netlify.
# (Ignored by GitHub Pages, which always serves max-age=600.)

# Hashed Hugo asset bundles (CSS, JS, images) — content-addressed,
# safe to cache for a year.
/scss/*
  Cache-Control: public, max-age=31536000, immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable

# Vendor libraries served from /vendor/ are versioned by file content;
# new builds bump the file URL when content changes via Hugo's
# fingerprint, but vendor JS is currently un-fingerprinted, so use
# 1 week TTL — long enough to score, short enough to recover from a
# vendor swap without manual cache-busting.
/vendor/*
  Cache-Control: public, max-age=604800

# Static images and fonts under /images and /fonts — bytes effectively
# never change for a given URL.
/images/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# HTML and the few non-hashed assets — short TTL so content updates
# propagate quickly.
/*.html
  Cache-Control: public, max-age=600, must-revalidate
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# Security headers (free a11y/best-practices wins on most CDNs).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
